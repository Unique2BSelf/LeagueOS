datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  MODERATOR
  REF
  CAPTAIN
  PLAYER
  SPONSOR
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINAL
  DISPUTED
  RAINOUT
  FORFEIT
}

enum MatchType {
  REGULAR
  FRIENDLY
  BYE
}

enum TransactionType {
  REGISTRATION
  INSURANCE
  FINE
  REF_PAYOUT
  SPONSORSHIP
  DONATION
  REFUND
  REIMBURSEMENT
}

enum FileCategory {
  RULES
  FIELD_MAP
  WAIVER
  CERTIFICATION
  BACKGROUND_CHECK
  FUNDRAISING_FORM
  TEAM_ASSET
  REPORT
  PHOTO
  OTHER
}

enum FileVisibility {
  PUBLIC
  LEAGUE
  TEAM
  OWNER
  REF_ONLY
  ADMIN_ONLY
}

enum AuditActionType {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  ACTIVATE
  DEACTIVATE
  EXPORT
  SEND
}

enum AuditEntityType {
  SEASON
  DIVISION
  LOCATION
  FIELD
  TEAM
  REGISTRATION
  INSURANCE_POLICY
  USER
  REPORT
  COMMUNICATION
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum PaymentMethod {
  CARD
  CASH
  VENMO
  APPLE_PAY
  CHECK
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AvailabilityStatus {
  YES
  NO
  MAYBE
}

enum SubRequestStatus {
  OPEN
  CLAIMED
  CANCELLED
}

enum DisciplinaryStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TeamRosterStatus {
  DRAFT
  SUBMITTED
  FINALIZED
}

model User {
  id                String              @id @default(uuid())
  role              Role                @default(PLAYER)
  fullName          String
  email             String              @unique
  password          String
  photoUrl          String?
  isInsured         Boolean             @default(false)
  insuranceExpiry   DateTime?
  eloRating         Int                 @default(1200)
  isGoalie          Boolean             @default(false)
  // Skill Matrix (1-5)
  skillSpeed        Int                 @default(3)
  skillTechnical   Int                 @default(3)
  skillStamina     Int                 @default(3)
  skillTeamwork    Int                 @default(3)
  skillDefense     Int                 @default(3)
  skillAttack      Int                 @default(3)
  // Free agent status
  isFreeAgent      Boolean             @default(false)
  freeAgentSeasonId String?
  
  taxIdEncrypted    String?
  isActive          Boolean             @default(true)
  backgroundCheckStatus String?          @default("PENDING")
  lockReason         String?
  suspensionEndDate  DateTime?
  hideFromDirectory Boolean             @default(false)
  createdAt         DateTime            @default(now())

  teams             TeamPlayer[]
  ledgers           Ledger[]
  businesses        Business[]
  disciplinary      DisciplinaryAction[]
  ratings           RefRating[]         @relation("RaterRatings")
  refRatings        RefRating[]         @relation("RefRatings")
  backgroundChecks  BackgroundCheck[]
  volunteerShifts   VolunteerShift[]
  refereedMatches   Match[]             @relation("MatchRef")
  requestedSubs     Sub[]               @relation("RequestedSubs")
  claimedSubs       Sub[]               @relation("ClaimedSubs")
  matchAvailability MatchAvailability[]
  orders            Order[]
  registrations     Registration[]
  insurancePolicies InsurancePolicy[]
  payments          Payment[]
  messages          Message[]
  uploadedFiles     StoredFile[]
  certifications    OfficialCertification[]
}

model Team {
  id                String              @id @default(uuid())
  name              String
  captainId         String
  divisionId        String
  primaryColor      String
  secondaryColor   String
  jerseyPhotoUrl    String?
  escrowTarget      Float
  currentBalance    Float               @default(0)
  isConfirmed       Boolean             @default(false)
  isArchived        Boolean             @default(false)
  approvalStatus    String              @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason   String?             // Reason if rejected
  rosterStatus      TeamRosterStatus    @default(DRAFT)
  subQuotaRemaining Int                 @default(10)
  sponsorId         String?
  seasonId          String
  // Invite code for players to join
  inviteCode        String?             @unique
  inviteCodeExpiry  DateTime?
  // Captain credits for free subs/rewards
  captainCredits    Float               @default(0)
  captainCreditUsage Float              @default(0) // Track used credits

  players           TeamPlayer[]
  homeMatches       Match[]             @relation("Home")
  awayMatches       Match[]             @relation("Away")
  season            Season              @relation(fields: [seasonId], references: [id])
  division          Division            @relation(fields: [divisionId], references: [id])
}

model TeamPlayer {
  userId    String
  teamId    String
  status    String      @default("PENDING")
  joinedAt  DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id])
  team      Team        @relation(fields: [teamId], references: [id])

  @@id([userId, teamId])
}

model Match {
  id                String              @id @default(uuid())
  scheduledAt       DateTime
  fieldId           String
  homeTeamId        String
  awayTeamId        String
  refId             String?
  matchType         MatchType?          @default(REGULAR)
  gameLengthMinutes Int?                @default(60)
  homeScore         Int?
  awayScore         Int?
  currentMinute     Int                 @default(0)
  status            MatchStatus         @default(SCHEDULED)
  checklistDone     Boolean             @default(false)
  fieldInspected    Boolean             @default(false)
  playerCardsChecked Boolean            @default(false)
  teamsPresent      Boolean             @default(false)
  refereeConfirmed  Boolean             @default(false)
  startedAt         DateTime?
  endedAt           DateTime?
  streamLink        String?
  weatherStatus     String?
  reportNotes       String?
  seasonId          String

  homeTeam          Team                @relation("Home", fields: [homeTeamId], references: [id])
  awayTeam          Team                @relation("Away", fields: [awayTeamId], references: [id])
  ref               User?               @relation("MatchRef", fields: [refId], references: [id])
  subs              Sub[]
  availability      MatchAvailability[]
  disciplinary      DisciplinaryAction[]
  events            MatchEvent[]
  season            Season              @relation(fields: [seasonId], references: [id])
}

model Ledger {
  id            String              @id @default(uuid())
  userId        String
  amount        Float
  type          TransactionType
  status        String              @default("PENDING")
  year          Int
  description   String?
  matchId       String?
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id])
  payment       Payment?
}

model Sub {
  id            String              @id @default(uuid())
  matchId       String
  requestedById String
  claimedById   String?
  teamId        String
  type          String              @default("STANDARD")
  status        SubRequestStatus    @default(OPEN)
  approved      Boolean             @default(false)
  createdAt     DateTime            @default(now())

  match         Match               @relation(fields: [matchId], references: [id])
  requester     User                @relation("RequestedSubs", fields: [requestedById], references: [id])
  claimant      User?               @relation("ClaimedSubs", fields: [claimedById], references: [id])

  @@index([matchId, status])
  @@index([requestedById, createdAt])
  @@index([claimedById, createdAt])
}

model MatchAvailability {
  userId        String
  matchId       String
  status        AvailabilityStatus
  updatedAt     DateTime            @updatedAt
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id])
  match         Match               @relation(fields: [matchId], references: [id])

  @@id([userId, matchId])
  @@index([matchId, status])
}

model DisciplinaryAction {
  id            String              @id @default(uuid())
  userId        String
  matchId       String?
  cardType      String
  status        DisciplinaryStatus  @default(PENDING_REVIEW)
  fineAmount    Float
  isPaid        Boolean             @default(false)
  isReleased    Boolean             @default(false)
  suspensionGames Int
  source        String              @default("MATCH_REPORT")
  notes         String?
  reportNotes   String?
  reportedById  String?
  reviewedById  String?
  reviewedAt    DateTime?
  fineLedgerId  String?
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id])
  match         Match?              @relation(fields: [matchId], references: [id])

  @@index([userId, status])
  @@index([matchId, status])
}

model Business {
  id            String              @id @default(uuid())
  userId        String
  name          String
  category      String
  discount      String?
  logoUrl       String?
  contactInfo   String

  user          User                @relation(fields: [userId], references: [id])
}

model Location {
  id            String              @id @default(uuid())
  name          String
  address       String
  latitude      Float?
  longitude     Float?
  notes         String?
  parkingInfo   String?
  restroomInfo  String?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  
  fields        Field[]
}

model Field {
  id            String              @id @default(uuid())
  locationId    String
  name          String
  qualityScore  Int
  hasLights     Boolean
  surfaceType   String?
  notes         String?

  location      Location            @relation(fields: [locationId], references: [id])
  maintenance   MaintenanceLog[]
}

model Season {
  id            String              @id @default(uuid())
  name          String
  startDate     DateTime
  endDate       DateTime?
  isArchived    Boolean             @default(false)
  scoringSystem String              @default("TRADITIONAL")
  minRosterSize Int
  maxRosterSize Int
  subQuota      Int

  teams         Team[]
  matches       Match[]
  divisions     Division[]
  registrations Registration[]
  pricingTiers  PricingTier[]
  registrationForm RegistrationForm?
  rulesDocument SeasonRulesDocument?
}

model SeasonRulesDocument {
  id            String    @id @default(uuid())
  seasonId      String    @unique
  title         String
  effectiveDate DateTime?
  summary       String?
  content       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  season        Season    @relation(fields: [seasonId], references: [id])
}

model Division {
  id            String              @id @default(uuid())
  name          String
  level         Int
  seasonId      String

  teams         Team[]
  season        Season              @relation(fields: [seasonId], references: [id])
}

model RefRating {
  id            String              @id @default(uuid())
  refId         String
  raterId       String
  rating        Int
  comments      String?

  ref           User                @relation("RefRatings", fields: [refId], references: [id])
  rater         User                @relation("RaterRatings", fields: [raterId], references: [id])
}

model BackgroundCheck {
  id            String              @id @default(uuid())
  userId        String
  provider      String
  status        String
  documentFileId String?
  notes         String?
  resultUrl     String?
  expiresAt     DateTime?
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id])
}

model OfficialCertification {
  id                 String    @id @default(uuid())
  userId             String
  fileId             String
  certificationType  String
  status             String    @default("ACTIVE")
  expiresAt          DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model VolunteerShift {
  id            String              @id @default(uuid())
  userId        String?
  eventId       String
  role          String
  hours         Float?
  status        String              @default("ASSIGNED")
  eventName     String?
  date          DateTime?
  startTime     String?
  endTime       String?
  notes         String?
  createdAt     DateTime            @default(now())

  user          User?               @relation(fields: [userId], references: [id])
}

model FundraisingCampaign {
  id            String              @id @default(uuid())
  name          String
  goalAmount    Float
  current       Float               @default(0)
  description   String?
  endDate       DateTime?
  createdAt     DateTime            @default(now())
}

model MaintenanceLog {
  id            String              @id @default(uuid())
  fieldId       String
  issue         String
  status        String              @default("OPEN")
  priority      String              @default("MEDIUM")
  notes         String?
  reportedBy    String?
  resolvedAt    DateTime?
  createdAt     DateTime            @default(now())

  field         Field               @relation(fields: [fieldId], references: [id])
}

model MatchEvent {
  id            String              @id @default(uuid())
  matchId       String
  type          String
  minute        Int                 @default(0)
  teamId        String?
  playerId      String?
  playerName    String?
  description   String?
  createdAt     DateTime            @default(now())

  match         Match               @relation(fields: [matchId], references: [id])

  @@index([matchId, createdAt])
}

// ============ FEATURE 7: MERCHANDISE/STORE ============

enum ProductCategory {
  JERSEYS
  APPAREL
  EQUIPMENT
  ACCESSORIES
}

model Product {
  id            String              @id @default(uuid())
  name          String
  description   String?
  category      ProductCategory
  basePrice     Float
  imageUrl      String?
  sizes         String[]            // XS, S, M, L, XL, XXL
  colors        String[]
  stock         Int                 @default(100)
  isActive      Boolean             @default(true)
  isFeatured    Boolean             @default(false)
  externalUrl   String?              // SquadLocker/Printful link
  createdAt     DateTime            @default(now())

  orderItems    OrderItem[]
}

model Order {
  id            String              @id @default(uuid())
  userId        String
  status        String              @default("PENDING")
  total         Float
  shippingAddress String?
  trackingNumber String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id])
  items         OrderItem[]
}

model OrderItem {
  id            String              @id @default(uuid())
  orderId       String
  productId     String
  quantity      Int
  size          String?
  color         String?
  priceAtPurchase Float

  order         Order               @relation(fields: [orderId], references: [id])
  product       Product             @relation(fields: [productId], references: [id])
}

// ============ FEATURE 8: ANALYTICS ============

model AnalyticsEvent {
  id            String              @id @default(uuid())
  eventType     String              // match_attendance, sub_request, donation, registration
  userId        String?
  teamId        String?
  matchId       String?
  metadata      Json?
  createdAt     DateTime            @default(now())
}

// ============ FEATURE 9: SEASON REGISTRATION & INSURANCE TRACKING ============

// Season Registration - tracks player signup per season
model Registration {
  id              String              @id @default(uuid())
  userId          String
  seasonId        String
  status          String              @default("PENDING") // PENDING, APPROVED, REJECTED
  rejectionReason String?             // Reason if rejected
  paid            Boolean             @default(false)
  paymentId       String?             // Stripe payment intent ID
  amount          Float
  insuranceStatus String              @default("PENDING") // PENDING, VALID, EXPIRED, REQUIRED
  insurancePurchasedAt DateTime?
  
  // Waiver acceptance
  waiverSignedAt   DateTime?          // When player signed the waiver
  waiverIpAddress String?             // IP address when signed
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id])
  season          Season              @relation(fields: [seasonId], references: [id])
  payments        Payment[]

  @@unique([userId, seasonId]) // One registration per user per season
}

model Payment {
  id                 String           @id @default(uuid())
  userId             String
  registrationId     String?
  ledgerEntryId      String?          @unique
  seasonId           String?
  amount             Float
  method             PaymentMethod
  status             PaymentStatus    @default(PENDING)
  transactionType    TransactionType
  stripeSessionId    String?          @unique
  stripePaymentIntentId String?
  providerReference  String?
  venmoHandle        String?
  notes              String?
  processedAt        DateTime?
  refundedAt         DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user               User             @relation(fields: [userId], references: [id])
  registration       Registration?    @relation(fields: [registrationId], references: [id])
  ledgerEntry        Ledger?          @relation(fields: [ledgerEntryId], references: [id])

  @@index([userId, createdAt])
  @@index([registrationId, status])
  @@index([seasonId, createdAt])
  @@index([transactionType, status])
}

// Insurance Policy - 365-day annual tracking per PRD
model InsurancePolicy {
  id              String              @id @default(uuid())
  userId          String
  provider        String              @default("LEAGUE_PROVIDED")
  policyNumber    String?
  startDate       DateTime
  endDate         DateTime            // 365 days from start
  cost            Float               @default(50.00)
  status          String              @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  stripePaymentId String?
  createdAt       DateTime            @default(now())

  user            User                @relation(fields: [userId], references: [id])

  @@index([userId, endDate]) // For expiry queries
}

// Tiered pricing per season (Early Bird → Regular → Late)
model PricingTier {
  id            String              @id @default(uuid())
  seasonId      String
  name          String              // "Early Bird", "Regular", "Late"
  startDate     DateTime
  endDate       DateTime
  amount        Float
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())

  season        Season              @relation(fields: [seasonId], references: [id])
}

// Chat Messages
model Message {
  id            String              @id @default(uuid())
  channel       String              // global, division-X, team-X, user-userId
  userId        String
  content       String
  isPinned      Boolean             @default(false)
  isDeleted     Boolean             @default(false)
  createdAt     DateTime            @default(now())

  user          User                @relation(fields: [userId], references: [id])

  @@index([channel, createdAt])
}

// Registration Form - Customizable form per season
model RegistrationForm {
  id                  String              @id @default(uuid())
  seasonId            String              @unique
  
  // Registration settings
  isEnabled           Boolean             @default(true)
  requireInsurance    Boolean             @default(true)
  
  // Waiver settings
  requireWaiver       Boolean             @default(false)
  waiverText          String?             // Custom waiver/terms text
  
  // Pricing
  baseFee             Float               @default(150.00)
  earlyBirdFee        Float?              // Optional early bird discount
  lateFee             Float?              // Optional late penalty
  paymentThankYouSubject String?
  paymentThankYouBody String?
  
  // Custom fields (JSON)
  customFields        Json                @default("[]")
  
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  season              Season              @relation(fields: [seasonId], references: [id])
}

model OutboundEmail {
  id                   String              @id @default(uuid())
  toEmail              String
  toName               String?
  subject              String
  htmlBody             String
  textBody             String?
  status               EmailDeliveryStatus @default(PENDING)
  templateType         String?
  audienceType         String?
  sentByUserId         String?
  relatedRegistrationId String?
  relatedSeasonId      String?
  relatedTeamId        String?
  relatedDivisionId    String?
  errorMessage         String?
  metadata             Json?
  createdAt            DateTime            @default(now())
  sentAt               DateTime?

  @@index([status, createdAt])
  @@index([toEmail, createdAt])
  @@index([relatedRegistrationId, createdAt])
  @@index([relatedSeasonId, createdAt])
}

model DiscountCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountType    String    // PERCENTAGE, FIXED
  discountValue   Float     // e.g., 10 for 10% or 10.00 for $10 off
  maxUses         Int?      // null = unlimited
  currentUses     Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  description     String?
  seasonId        String?   // null = all seasons
  createdAt       DateTime  @default(now())
}

model StoredFile {
  id             String         @id @default(uuid())
  displayName    String
  originalName   String
  storageKey     String         @unique
  mimeType       String
  sizeBytes      Int
  category       FileCategory   @default(OTHER)
  visibility     FileVisibility @default(LEAGUE)
  description    String?
  uploadedById   String
  teamId         String?
  seasonId       String?
  subjectUserId  String?
  isArchived     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  uploadedBy     User           @relation(fields: [uploadedById], references: [id])

  @@index([visibility, createdAt])
  @@index([uploadedById, createdAt])
  @@index([teamId, createdAt])
  @@index([subjectUserId, createdAt])
}

model AuditLog {
  id            String           @id @default(uuid())
  actorUserId   String
  actorEmail    String?
  actionType    AuditActionType
  entityType    AuditEntityType
  entityId      String
  before        Json?
  after         Json?
  notes         String?
  createdAt     DateTime         @default(now())

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([actionType, createdAt])
}
